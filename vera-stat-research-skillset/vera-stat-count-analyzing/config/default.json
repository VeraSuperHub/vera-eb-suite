{
  "outcome_type": "count",
  "languages": [
    "R",
    "Python"
  ],
  "plot_dpi": 300,
  "alpha": 0.05,
  "ci_level": 0.95,
  "overdispersion_threshold": 1.5,
  "zero_proportion_threshold": 0.2,
  "p_value_format": {
    "threshold": 0.001,
    "below_threshold": "< .001",
    "decimals": 3
  },
  "count_models": {
    "poisson": true,
    "negative_binomial": true,
    "zero_inflated_poisson": true,
    "zero_inflated_negbin": true,
    "hurdle": true
  },
  "subgroup_min_n": 5,
  "tree_models": {
    "cart_max_depth": 4,
    "rf_n_trees": 500,
    "lightgbm": {
      "n_estimators": 500,
      "max_depth": 3,
      "learning_rate": 0.1,
      "num_leaves": 15,
      "min_child_samples": "max(3, N // 10)"
    },
    "small_n_threshold": 200
  },
  "manuscript": {
    "style": "APA7",
    "decimal_places_stats": 2,
    "decimal_places_p": 3,
    "decimal_places_effect": 3
  },
  "code_style_variation": {
    "enabled": true,
    "dimensions": 7,
    "spec": "reference/specs/code-style-variation.md"
  },
  "output_variation": {
    "enabled": true,
    "protocol": "reference/specs/output-variation-protocol.md",
    "sentence_bank": "reference/patterns/sentence-bank.md"
  }
}
