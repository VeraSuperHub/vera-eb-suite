{
  "outcome_type": "continuous_repeated",
  "languages": [
    "R",
    "Python"
  ],
  "plot_dpi": 300,
  "alpha": 0.05,
  "ci_level": 0.95,
  "sphericity_alpha": 0.05,
  "icc_threshold": 0.05,
  "missing_data_threshold": 0.2,
  "p_value_format": {
    "threshold": 0.001,
    "below_threshold": "< .001",
    "decimals": 3
  },
  "subgroup_min_n": 5,
  "lmm": {
    "estimation": "REML",
    "estimation_comparison": "ML",
    "optimizer": "bobyqa",
    "df_method": "Satterthwaite",
    "random_effects": [
      "intercept_only",
      "intercept_slope"
    ],
    "growth_curve_max_polynomial": 2
  },
  "gee": {
    "correlation_structures": [
      "exchangeable",
      "ar1",
      "unstructured"
    ],
    "default_corstr": "exchangeable",
    "robust_se": true
  },
  "tree_models": {
    "rf_n_trees": 500,
    "lightgbm": {
      "n_estimators": 500,
      "max_depth": 3,
      "learning_rate": 0.1,
      "num_leaves": 15,
      "min_child_samples": "max(3, N // 10)"
    },
    "small_n_threshold": 200
  },
  "pairwise_correction": [
    "bonferroni",
    "holm",
    "fdr"
  ],
  "default_correction": "bonferroni",
  "manuscript": {
    "style": "APA7",
    "decimal_places_stats": 2,
    "decimal_places_p": 3,
    "decimal_places_effect": 3
  },
  "code_style_variation": {
    "enabled": true,
    "dimensions": 7,
    "spec": "reference/specs/code-style-variation.md"
  },
  "output_variation": {
    "enabled": true,
    "protocol": "reference/specs/output-variation-protocol.md",
    "sentence_bank": "reference/patterns/sentence-bank.md"
  }
}
