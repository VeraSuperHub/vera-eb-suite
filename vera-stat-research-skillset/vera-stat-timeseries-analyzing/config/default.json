{
  "outcome_type": "timeseries",
  "languages": [
    "R",
    "Python"
  ],
  "plot_dpi": 300,
  "alpha": 0.05,
  "ci_level": 0.95,
  "p_value_format": {
    "threshold": 0.001,
    "below_threshold": "< .001",
    "decimals": 3
  },
  "stationarity_tests": {
    "adf_max_lags": "auto",
    "kpss_regression": "ct"
  },
  "arima": {
    "auto_selection": true,
    "stepwise": false,
    "approximation": false,
    "max_p": 5,
    "max_d": 2,
    "max_q": 5,
    "information_criterion": "aic"
  },
  "sarima": {
    "max_P": 2,
    "max_D": 1,
    "max_Q": 2
  },
  "ets": {
    "automatic": true,
    "damped": "auto"
  },
  "garch": {
    "order": [
      1,
      1
    ],
    "arch_lm_lags": 12,
    "fit_condition": "arch_lm_p < 0.05"
  },
  "var": {
    "max_lag": 12,
    "lag_selection": [
      "aic",
      "bic",
      "hq"
    ],
    "fit_condition": "exogenous_present"
  },
  "forecast": {
    "holdout_ratio": 0.2,
    "prediction_intervals": [
      0.8,
      0.95
    ],
    "accuracy_metrics": [
      "mae",
      "rmse",
      "mape"
    ]
  },
  "tree_models": {
    "rf_n_trees": 500,
    "lightgbm": {
      "n_estimators": 500,
      "max_depth": 3,
      "learning_rate": 0.1,
      "num_leaves": 15,
      "min_child_samples": "max(3, N // 10)"
    },
    "small_n_threshold": 200
  },
  "rolling_window": {
    "min_window": 30,
    "step": "frequency"
  },
  "manuscript": {
    "style": "APA7",
    "decimal_places_stats": 2,
    "decimal_places_p": 3,
    "decimal_places_effect": 3
  },
  "code_style_variation": {
    "enabled": true,
    "dimensions": 7,
    "spec": "reference/specs/code-style-variation.md"
  },
  "output_variation": {
    "enabled": true,
    "protocol": "reference/specs/output-variation-protocol.md",
    "sentence_bank": "reference/patterns/sentence-bank.md"
  }
}
