{
  "outcome_type": "ordinal",
  "languages": [
    "R",
    "Python"
  ],
  "plot_dpi": 300,
  "alpha": 0.05,
  "ci_level": 0.95,
  "sparse_level_threshold": 5,
  "p_value_format": {
    "threshold": 0.001,
    "below_threshold": "< .001",
    "decimals": 3
  },
  "subgroup_min_n": 5,
  "descriptive_stats": {
    "central_tendency": "median",
    "spread": "IQR",
    "proportions_decimals": 1
  },
  "proportional_odds": {
    "brant_alpha": 0.05,
    "fallback_if_violated": [
      "adjacent_category",
      "continuation_ratio",
      "stereotype"
    ],
    "report_cumulative_or": true
  },
  "multinomial_logistic": {
    "reference_category": "lowest",
    "report_class_specific_or": true
  },
  "adjacent_category": {
    "enabled": true,
    "family": "acat"
  },
  "continuation_ratio": {
    "enabled": true,
    "family": "cratio"
  },
  "stereotype": {
    "enabled": true
  },
  "lightgbm": {
    "n_estimators": 500,
    "max_depth": 3,
    "learning_rate": 0.01,
    "num_leaves": 31,
    "path_a_objective": "multiclass",
    "path_b_objective": "regression",
    "importance_type": "gain"
  },
  "spearman": {
    "ci_method": "fisher_z"
  },
  "tree_models": {
    "cart_max_depth": 4,
    "rf_n_trees": 500,
    "rf_importance": "permutation",
    "small_n_threshold": 200
  },
  "manuscript": {
    "style": "APA7",
    "decimal_places_stats": 2,
    "decimal_places_p": 3,
    "decimal_places_effect": 3,
    "decimal_places_or": 2,
    "decimal_places_proportions": 1
  },
  "code_style_variation": {
    "enabled": true,
    "dimensions": 7,
    "spec": "reference/specs/code-style-variation.md"
  },
  "output_variation": {
    "enabled": true,
    "protocol": "reference/specs/output-variation-protocol.md",
    "sentence_bank": "reference/patterns/sentence-bank.md"
  }
}
