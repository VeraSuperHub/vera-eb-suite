{
  "family": "sem",
  "subtype": "full",
  "languages": [
    "R",
    "Python"
  ],
  "primary_engine": "lavaan",
  "secondary_engine": "semopy",
  "alpha": 0.05,
  "ci_level": 0.95,
  "fit_indices": [
    "chisq",
    "df",
    "cfi",
    "tli",
    "rmsea",
    "srmr"
  ],
  "bootstrap_indirects": true,
  "bootstrap_draws": 5000,
  "candidate_models": [
    "direct_effects_only",
    "partial_mediation",
    "full_mediation",
    "theory_restricted_alternative"
  ],
  "manuscript": {
    "style": "APA7",
    "decimal_places_stats": 2,
    "decimal_places_p": 3,
    "decimal_places_effect": 3
  },
  "code_style_variation": {
    "enabled": true,
    "dimensions": 7,
    "spec": "reference/specs/code-style-variation.md"
  },
  "output_variation": {
    "enabled": true,
    "protocol": "reference/specs/output-variation-protocol.md",
    "sentence_bank": "reference/patterns/sentence-bank.md"
  }
}
