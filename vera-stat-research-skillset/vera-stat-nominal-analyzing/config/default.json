{
  "outcome_type": "nominal",
  "languages": [
    "R",
    "Python"
  ],
  "plot_dpi": 300,
  "alpha": 0.05,
  "ci_level": 0.95,
  "p_value_format": {
    "threshold": 0.001,
    "below_threshold": "< .001",
    "decimals": 3
  },
  "subgroup_min_n": 5,
  "rare_class_threshold": 0.05,
  "multinomial_logistic": {
    "reference_category": "most_frequent",
    "report_rrr": true,
    "lr_test_per_predictor": true
  },
  "lda": {
    "report_loadings": true,
    "report_wilks_lambda": true,
    "report_canonical_correlations": true
  },
  "tree_models": {
    "cart_max_depth": 4,
    "rf_n_trees": 500,
    "lightgbm": {
      "objective": "multiclass",
      "n_estimators": 500,
      "max_depth": 3,
      "learning_rate": 0.1,
      "num_leaves": 15,
      "min_child_samples": "max(3, N // 10)"
    },
    "small_n_threshold": 200
  },
  "confusion_matrix": {
    "report_overall_accuracy": true,
    "report_per_class_precision": true,
    "report_per_class_recall": true,
    "in_sample_caveat": true
  },
  "unified_importance": {
    "scale": [
      0,
      100
    ],
    "methods": [
      "multinomial_std_coef",
      "lda_loadings",
      "rf_importance",
      "lightgbm_gain"
    ],
    "rank_consensus": "average_rank"
  },
  "manuscript": {
    "style": "APA7",
    "decimal_places_stats": 2,
    "decimal_places_p": 3,
    "decimal_places_effect": 3,
    "decimal_places_rrr": 2
  },
  "code_style_variation": {
    "enabled": true,
    "dimensions": 7,
    "spec": "reference/specs/code-style-variation.md"
  },
  "output_variation": {
    "enabled": true,
    "protocol": "reference/specs/output-variation-protocol.md",
    "sentence_bank": "reference/patterns/sentence-bank.md"
  }
}
