{
  "outcome_type": "multivariate",
  "languages": [
    "R",
    "Python"
  ],
  "plot_dpi": 300,
  "alpha": 0.05,
  "ci_level": 0.95,
  "box_m_alpha": 0.001,
  "bonferroni_correction": true,
  "p_value_format": {
    "threshold": 0.001,
    "below_threshold": "< .001",
    "decimals": 3
  },
  "manova": {
    "test_statistics": [
      "Pillai",
      "Wilks",
      "Hotelling-Lawley",
      "Roy"
    ],
    "primary_if_robust": "Pillai",
    "primary_if_assumptions_met": "Wilks"
  },
  "discriminant": {
    "classification_method": "leave-one-out",
    "report_structure_coefficients": true,
    "loading_threshold": 0.4
  },
  "pca": {
    "scale": true,
    "retention_criterion": "kaiser",
    "loading_threshold": 0.4
  },
  "cca": {
    "report_redundancy": true,
    "significance_test": "wilks_lambda"
  },
  "profile_analysis": {
    "requires_same_scale": true,
    "tests": [
      "parallelism",
      "equal_levels",
      "flatness"
    ]
  },
  "tree_models": {
    "rf_n_trees": 500,
    "lightgbm": {
      "n_estimators": 500,
      "max_depth": 3,
      "learning_rate": 0.1,
      "num_leaves": 15,
      "min_child_samples": "max(3, N // 10)"
    },
    "small_n_threshold": 200
  },
  "manuscript": {
    "style": "APA7",
    "decimal_places_stats": 2,
    "decimal_places_p": 3,
    "decimal_places_effect": 3
  },
  "code_style_variation": {
    "enabled": true,
    "dimensions": 7,
    "spec": "reference/specs/code-style-variation.md"
  },
  "output_variation": {
    "enabled": true,
    "protocol": "reference/specs/output-variation-protocol.md",
    "sentence_bank": "reference/patterns/sentence-bank.md"
  }
}
